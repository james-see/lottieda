---
import "../styles/global.css";
---

<main class="page">
  <section class="hero">
    <p>LottieDa</p>
    <h1>Native desktop editing for Lottie animations.</h1>
    <p>
      A self-contained Tauri app for drawing, keyframing, previewing, importing SVG, and saving Lottie JSON without
      accounts or cloud dependencies.
    </p>
    <div class="cta-row">
      <a id="download-link" class="button primary" href="https://github.com/james-see/lottieda/releases/latest">Download latest release</a>
      <a class="button" href="docs/">Read the docs</a>
    </div>
    <p id="download-note" class="muted">macOS DMG builds are published from the latest GitHub release.</p>
  </section>

  <section class="card-grid">
    <article class="card">
      <h2>Canvas Editor</h2>
      <p>Draw rectangles, ellipses, and paths on an interactive Canvas 2D workspace.</p>
    </article>
    <article class="card">
      <h2>Lottie Preview</h2>
      <p>Preview the current JSON document through bundled lottie-web.</p>
    </article>
    <article class="card">
      <h2>Offline First</h2>
      <p>No CDN, no account, no phoning home. Your animation files stay local.</p>
    </article>
  </section>

  <section class="download-grid" aria-label="Download options">
    <article class="card">
      <h2>macOS</h2>
      <p>Download the signed DMG from the latest release.</p>
      <a href="https://github.com/james-see/lottieda/releases/latest">Latest macOS release</a>
    </article>
    <article class="card">
      <h2>Windows</h2>
      <p>Windows builds are not published yet. Follow releases for availability.</p>
      <a href="https://github.com/james-see/lottieda/releases">View releases</a>
    </article>
    <article class="card">
      <h2>Linux</h2>
      <p>Linux builds are not published yet. Follow releases for availability.</p>
      <a href="https://github.com/james-see/lottieda/releases">View releases</a>
    </article>
  </section>
</main>

<script>
  const link = document.querySelector<HTMLAnchorElement>("#download-link");
  const note = document.querySelector<HTMLElement>("#download-note");
  const userAgent = navigator.userAgent.toLowerCase();
  const platform = navigator.platform.toLowerCase();

  if (link && note) {
    if (platform.includes("mac") || userAgent.includes("mac os")) {
      link.textContent = "Download for macOS";
      note.textContent = "You are on macOS. Grab the latest signed DMG from GitHub Releases.";
    } else if (platform.includes("win") || userAgent.includes("windows")) {
      link.textContent = "View Windows release options";
      note.textContent = "Windows builds are not published yet. The release page has the latest available downloads.";
    } else if (platform.includes("linux") || userAgent.includes("linux")) {
      link.textContent = "View Linux release options";
      note.textContent = "Linux builds are not published yet. The release page has the latest available downloads.";
    }
  }
</script>
